<configuration>

    <!-- Консоль: человекочитаемый формат для локальной разработки -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%mdc{call_id:-no-call}] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!--
        Grafana Cloud Loki appender. Сообщения уходят как JSON, чтобы все MDC-поля
        (call_id, http_method, http_path, http_status, duration_ms, user_id, ...) и stack_trace
        были индексируемыми в LogQL через `| json field="value"`.

        Требует переменных окружения:
          LOKI_URL      — хост без пути, напр. https://logs-prod-eu-west-0.grafana.net
          LOKI_USER_ID  — числовой User ID из раздела Loki в Grafana Cloud
          LOKI_API_KEY  — API Key (пароль) из Grafana Cloud
    -->
    <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
        <http>
            <url>${LOKI_URL:-http://localhost:3100}/loki/api/v1/push</url>
            <auth>
                <username>${LOKI_USER_ID:-}</username>
                <password>${LOKI_API_KEY:-}</password>
            </auth>
            <connectionTimeoutMs>5000</connectionTimeoutMs>
            <requestTimeoutMs>5000</requestTimeoutMs>
        </http>
        <format>
            <label>
                <pattern>app=esport,level=%level,host=${HOSTNAME:-local}</pattern>
                <readMarker>true</readMarker>
            </label>
            <message class="net.logstash.logback.encoder.LogstashEncoder">
                <!-- Включаем все MDC ключи как структурированные JSON-поля -->
                <includeMdcKeyName>call_id</includeMdcKeyName>
                <includeMdcKeyName>http_method</includeMdcKeyName>
                <includeMdcKeyName>http_path</includeMdcKeyName>
                <includeMdcKeyName>http_status</includeMdcKeyName>
                <includeMdcKeyName>duration_ms</includeMdcKeyName>
                <includeMdcKeyName>user_id</includeMdcKeyName>
                <includeMdcKeyName>remote_host</includeMdcKeyName>
                <includeMdcKeyName>user_agent</includeMdcKeyName>
                <includeMdcKeyName>query</includeMdcKeyName>
                <fieldNames>
                    <timestamp>ts</timestamp>
                    <message>msg</message>
                    <thread>thread</thread>
                    <levelValue>[ignore]</levelValue>
                    <logger>logger</logger>
                    <stackTrace>stack_trace</stackTrace>
                </fieldNames>
            </message>
            <sortByTime>true</sortByTime>
        </format>
    </appender>

    <!-- SQL запросы Exposed (включить, если нужно отлаживать запросы) -->
    <logger name="Exposed" level="INFO" additivity="false">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="LOKI"/>
    </logger>

    <logger name="org.eclipse.jetty" level="INFO"/>
    <logger name="io.netty" level="INFO"/>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="LOKI"/>
    </root>

</configuration>
